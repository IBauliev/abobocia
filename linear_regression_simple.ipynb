{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Линейная регрессия проект\n",
    "\n",
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Ответы на вопросы\n",
    "\n",
    "1. Аналитическое решение: w = (X^T X)^-1 X^T y\n",
    "\n",
    "2. L2 регуляризация добавляет lambda * w^2 к потере\n",
    "   L1 регуляризация добавляет lambda * |w| к потере\n",
    "\n",
    "3. L1 обнуляет веса неважных признаков\n",
    "\n",
    "4. Для нелинейных зависимостей добавляем полиномы признаков"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "from collections import Counter\n",
    "from sklearn.metrics import mean_absolute_error, mean_squared_error, r2_score\n",
    "from sklearn.linear_model import LinearRegression, Ridge, Lasso, ElasticNet\n",
    "from sklearn.preprocessing import MinMaxScaler, StandardScaler\n",
    "from sklearn.preprocessing import PolynomialFeatures"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "train = pd.read_csv('../datasets/train.csv')\n",
    "test = pd.read_csv('../datasets/test.csv')\n",
    "\n",
    "print(train.shape, test.shape)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def clean_features(text):\n",
    "    if pd.isna(text):\n",
    "        return []\n",
    "    text = text.replace('[', '').replace(']', '').replace(\"'\", '').replace('\"', '').replace(' ', '')\n",
    "    return text.split(',') if text else []\n",
    "\n",
    "train['features_clean'] = train['features'].apply(clean_features)\n",
    "test['features_clean'] = test['features'].apply(clean_features)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "all_features = []\n",
    "for features in train['features_clean']:\n",
    "    all_features.extend(features)\n",
    "\n",
    "top_features = [f for f, _ in Counter(all_features).most_common(20)]\n",
    "print('Топ признаков:', top_features[:5])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "for feature in top_features:\n",
    "    train[f'has_{feature}'] = train['features_clean'].apply(lambda x: 1 if feature in x else 0)\n",
    "    test[f'has_{feature}'] = test['features_clean'].apply(lambda x: 1 if feature in x else 0)\n",
    "\n",
    "feature_list = ['bathrooms', 'bedrooms'] + [f'has_{f}' for f in top_features]\n",
    "\n",
    "X_train = train[feature_list]\n",
    "X_test = test[feature_list]\n",
    "y_train = train['price']\n",
    "y_test = test['price']\n",
    "\n",
    "print('Признаков:', len(feature_list))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "lr = LinearRegression()\n",
    "lr.fit(X_train, y_train)\n",
    "\n",
    "train_pred = lr.predict(X_train)\n",
    "test_pred = lr.predict(X_test)\n",
    "\n",
    "print('MAE train:', mean_absolute_error(y_train, train_pred))\n",
    "print('MAE test:', mean_absolute_error(y_test, test_pred))\n",
    "print('R2 test:', r2_score(y_test, test_pred))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "ridge = Ridge(alpha=0.1)\n",
    "ridge.fit(X_train, y_train)\n",
    "\n",
    "ridge_pred = ridge.predict(X_test)\n",
    "print('Ridge MAE:', mean_absolute_error(y_test, ridge_pred))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "lasso = Lasso(alpha=0.1)\n",
    "lasso.fit(X_train, y_train)\n",
    "\n",
    "lasso_pred = lasso.predict(X_test)\n",
    "print('Lasso MAE:', mean_absolute_error(y_test, lasso_pred))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "elastic = ElasticNet(alpha=0.1, l1_ratio=0.5)\n",
    "elastic.fit(X_train, y_train)\n",
    "\n",
    "elastic_pred = elastic.predict(X_test)\n",
    "print('ElasticNet MAE:', mean_absolute_error(y_test, elastic_pred))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "scaler = MinMaxScaler()\n",
    "X_train_scaled = scaler.fit_transform(X_train)\n",
    "X_test_scaled = scaler.transform(X_test)\n",
    "\n",
    "lr_scaled = LinearRegression()\n",
    "lr_scaled.fit(X_train_scaled, y_train)\n",
    "\n",
    "scaled_pred = lr_scaled.predict(X_test_scaled)\n",
    "print('MinMax MAE:', mean_absolute_error(y_test, scaled_pred))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "standard = StandardScaler()\n",
    "X_train_std = standard.fit_transform(X_train)\n",
    "X_test_std = standard.transform(X_test)\n",
    "\n",
    "lr_std = LinearRegression()\n",
    "lr_std.fit(X_train_std, y_train)\n",
    "\n",
    "std_pred = lr_std.predict(X_test_std)\n",
    "print('Standard MAE:', mean_absolute_error(y_test, std_pred))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "poly = PolynomialFeatures(degree=10)\n",
    "\n",
    "X_train_basic = X_train[['bathrooms', 'bedrooms']]\n",
    "X_test_basic = X_test[['bathrooms', 'bedrooms']]\n",
    "\n",
    "X_train_poly = poly.fit_transform(X_train_basic)\n",
    "X_test_poly = poly.transform(X_test_basic)\n",
    "\n",
    "print('Размерность:', X_train_poly.shape)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "lr_poly = LinearRegression()\n",
    "ridge_poly = Ridge(alpha=1.0)\n",
    "lasso_poly = Lasso(alpha=0.1)\n",
    "\n",
    "lr_poly.fit(X_train_poly, y_train)\n",
    "ridge_poly.fit(X_train_poly, y_train)\n",
    "lasso_poly.fit(X_train_poly, y_train)\n",
    "\n",
    "print('LR Poly MAE:', mean_absolute_error(y_test, lr_poly.predict(X_test_poly)))\n",
    "print('Ridge Poly MAE:', mean_absolute_error(y_test, ridge_poly.predict(X_test_poly)))\n",
    "print('Lasso Poly MAE:', mean_absolute_error(y_test, lasso_poly.predict(X_test_poly)))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "mean_pred = [np.mean(y_train)] * len(y_test)\n",
    "median_pred = [np.median(y_train)] * len(y_test)\n",
    "\n",
    "print('Mean baseline MAE:', mean_absolute_error(y_test, mean_pred))\n",
    "print('Median baseline MAE:', mean_absolute_error(y_test, median_pred))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "results = []\n",
    "\n",
    "def add_result(name, train_pred, test_pred):\n",
    "    results.append({\n",
    "        'model': name,\n",
    "        'MAE_train': mean_absolute_error(y_train, train_pred),\n",
    "        'MAE_test': mean_absolute_error(y_test, test_pred),\n",
    "        'RMSE_test': np.sqrt(mean_squared_error(y_test, test_pred)),\n",
    "        'R2_test': r2_score(y_test, test_pred)\n",
    "    })\n",
    "\n",
    "add_result('Linear', lr.predict(X_train), lr.predict(X_test))\n",
    "add_result('Ridge', ridge.predict(X_train), ridge.predict(X_test))\n",
    "add_result('Lasso', lasso.predict(X_train), lasso.predict(X_test))\n",
    "add_result('ElasticNet', elastic.predict(X_train), elastic.predict(X_test))\n",
    "add_result('Linear_MinMax', lr_scaled.predict(X_train_scaled), lr_scaled.predict(X_test_scaled))\n",
    "add_result('Linear_Standard', lr_std.predict(X_train_std), lr_std.predict(X_test_std))\n",
    "add_result('Linear_Poly', lr_poly.predict(X_train_poly), lr_poly.predict(X_test_poly))\n",
    "add_result('Ridge_Poly', ridge_poly.predict(X_train_poly), ridge_poly.predict(X_test_poly))\n",
    "add_result('Lasso_Poly', lasso_poly.predict(X_train_poly), lasso_poly.predict(X_test_poly))\n",
    "add_result('Mean_Baseline', [np.mean(y_train)]*len(y_train), mean_pred)\n",
    "add_result('Median_Baseline', [np.median(y_train)]*len(y_train), median_pred)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "results_df = pd.DataFrame(results)\n",
    "print(results_df.round(2))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "best = results_df.loc[results_df['MAE_test'].idxmin()]\n",
    "print(f'Лучшая модель: {best[\"model\"]} с MAE = {best[\"MAE_test\"]:.2f}')\n",
    "\n",
    "results_df['diff'] = results_df['MAE_test'] - results_df['MAE_train']\n",
    "stable = results_df.loc[results_df['diff'].abs().idxmin()]\n",
    "print(f'Самая стабильная: {stable[\"model\"]} с разницей {stable[\"diff\"]:.2f}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "y_train_log = np.log1p(y_train)\n",
    "\n",
    "lr_log = LinearRegression()\n",
    "lr_log.fit(X_train, y_train_log)\n",
    "\n",
    "log_pred = np.expm1(lr_log.predict(X_test))\n",
    "print('Log target MAE:', mean_absolute_error(y_test, log_pred))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "Q1 = y_train.quantile(0.25)\n",
    "Q3 = y_train.quantile(0.75)\n",
    "IQR = Q3 - Q1\n",
    "\n",
    "mask = (y_train >= Q1 - 1.5*IQR) & (y_train <= Q3 + 1.5*IQR)\n",
    "X_train_clean = X_train[mask]\n",
    "y_train_clean = y_train[mask]\n",
    "\n",
    "lr_clean = LinearRegression()\n",
    "lr_clean.fit(X_train_clean, y_train_clean)\n",
    "\n",
    "clean_pred = lr_clean.predict(X_test)\n",
    "print('Без выбросов MAE:', mean_absolute_error(y_test, clean_pred))\n",
    "print(f'Удалено {len(y_train) - len(y_train_clean)} выбросов')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
   ]
  }
 ],
